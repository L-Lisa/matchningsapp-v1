# Supabase – från ditt Supabase-projekt (Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Bcrypt-hash av ditt applikationslösenord
# Generera: node -e "require('bcryptjs').hash('dittlösenord',10).then(console.log)"
VITE_APP_PASSWORD_HASH=

# Delas med api/match.js – lägg in samma värde i Vercel Dashboard som APP_SECRET
VITE_APP_SECRET=

# --- Sätts i Vercel Dashboard (aldrig lokalt i .env) ---
# ANTHROPIC_API_KEY=sk-ant-...
# APP_SECRET=samma värde som VITE_APP_SECRET
