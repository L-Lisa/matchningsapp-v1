# Google OAuth – från Google Cloud Console
VITE_GOOGLE_CLIENT_ID=

# Google Sheet ID – strängen mellan /d/ och /edit i Sheet-URL:en
VITE_GOOGLE_SHEET_ID=

# Bcrypt-hash av ditt applikationslösenord
# Generera: node -e "require('bcryptjs').hash('dittlösenord',10).then(console.log)"
VITE_APP_PASSWORD_HASH=

# Delas med api/match.js – måste matcha APP_SECRET i Vercel Dashboard
VITE_APP_SECRET=

# --- Sätts i Vercel Dashboard (aldrig lokalt i .env) ---
# ANTHROPIC_API_KEY=sk-ant-...
# APP_SECRET=samma värde som VITE_APP_SECRET
